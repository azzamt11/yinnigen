    "yinni-service-proto-products": {
        "prefix": "yinni-service-pp",
        "body": [
            "// api/product/v1/product.proto",
            "syntax = \"proto3\";",
            "",
            "package api.product.v1;",
            "",
            "import \"google/api/annotations.proto\";",
            "import \"google/protobuf/timestamp.proto\";",
            "import \"google/protobuf/empty.proto\";",
            "import \"api/product/v1/product_error_reason.proto\";",
            "",
            "option go_package = \"yinni_backend/api/product/v1;v1\";",
            "option java_multiple_files = true;",
            "option java_package = \"api.product.v1\";",
            "",
            "service Product {",
            "\t// Get product by ID",
            "\trpc GetProduct(GetProductRequest) returns (ProductInfo) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/products/id/{id}\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Get product by Flipkart PID",
            "\trpc GetProductByPID(GetProductByPIDRequest) returns (ProductInfo) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/products/pid/{pid}\"",
            "\t\t};",
            "\t}",
            "",
            "\t// List products",
            "\trpc ListProducts(ListProductsRequest) returns (ListProductsReply) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/products\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Search products",
            "\trpc SearchProducts(SearchProductsRequest) returns (ListProductsReply) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/products/search\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Get featured products",
            "\trpc GetFeaturedProducts(GetFeaturedProductsRequest) returns (ListProductsReply) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/products/featured\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Get similar products",
            "\trpc GetSimilarProducts(GetSimilarProductsRequest) returns (ListProductsReply) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/products/{id}/similar\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Admin-only: Generate embeddings",
            "\trpc GenerateEmbeddings(GenerateEmbeddingsRequest) returns (GenerateEmbeddingsResponse) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tpost: \"/v1/admin/embeddings/generate\"",
            "\t\t\tbody: \"*\"",
            "\t\t};",
            "\t}",
            "\t",
            "\t//Admin-only: Get embedding status ",
            "\trpc GetEmbeddingStatus(GetEmbeddingStatusRequest) returns (GetEmbeddingStatusResponse) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/admin/embeddings/status\"",
            "\t\t};",
            "\t}",
            "\t",
            "\t//Admin-only: Cancel embedding generation",
            "\trpc CancelEmbeddingGeneration(google.protobuf.Empty) returns (google.protobuf.Empty) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tpost: \"/v1/admin/embeddings/cancel\"",
            "\t\t\tbody: \"*\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Admin-only: Start runtime product seeding job",
            "\trpc StartProductSeedJob(StartProductSeedJobRequest) returns (StartProductSeedJobResponse) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tpost: \"/v1/admin/products/seed\"",
            "\t\t\tbody: \"*\"",
            "\t\t};",
            "\t}",
            "",
            "\t// Admin-only: Get runtime product seeding job status",
            "\trpc GetProductSeedJobStatus(GetProductSeedJobStatusRequest) returns (GetProductSeedJobStatusResponse) {",
            "\t\toption (google.api.http) = {",
            "\t\t\tget: \"/v1/admin/products/seed/status\"",
            "\t\t};",
            "\t}",
            "}",
            "",
            "// ========== REQUEST MESSAGES ==========",
            "",
            "message GetProductRequest {",
            "\tint64 id = 1;",
            "}",
            "",
            "message GetProductByPIDRequest {",
            "\tstring pid = 1;",
            "}",
            "",
            "message ListProductsRequest {",
            "\tint32 page = 1;",
            "\tint32 page_size = 2;",
            "\tstring category = 3;",
            "\tstring brand = 4;",
            "\tstring sub_category = 5;",
            "\tint32 min_price = 6;",
            "\tint32 max_price = 7;",
            "\tfloat min_rating = 8;",
            "\tbool in_stock = 9;",
            "\tbool featured_only = 10;",
            "\tstring seller = 11;",
            "\tstring sort_by = 12;\t// \"price\", \"rating\", \"newest\", \"popular\"",
            "\tstring sort_order = 13; // \"asc\", \"desc\"",
            "\tstring search_query = 14;",
            "}",
            "",
            "message SearchProductsRequest {",
            "\tstring query = 1;",
            "\tint32 limit = 2;",
            "\tstring category = 3;",
            "\tPriceRange price_range = 4;",
            "}",
            "",
            "message GetFeaturedProductsRequest {",
            "\tint32 limit = 1;",
            "\tstring category = 2;",
            "}",
            "",
            "message GetSimilarProductsRequest {",
            "\tint64 id = 1;",
            "\tint32 limit = 2;",
            "}",
            "",
            "message GenerateEmbeddingsRequest {",
            "\tbool regenerate_all = 1;\t// Whether to regenerate all embeddings",
            "\tint32 batch_size = 2;\t\t // Batch size for processing",
            "\trepeated int64 product_ids = 3;\t// Specific products to process",
            "}",
            "",
            "message GetEmbeddingStatusRequest {",
            "\tstring job_id = 1;",
            "}",
            "",
            "message StartProductSeedJobRequest {",
            "\tbool clear_existing = 1;",
            "\tint32 max_products = 2;\t// 0 means seed all products from dataset",
            "\tint32 batch_size = 3;\t\t// 0 means default batch size",
            "}",
            "",
            "message GetProductSeedJobStatusRequest {",
            "\tstring job_id = 1;",
            "}",
            "",
            "// ========== RESPONSE MESSAGES ==========",
            "",
            "message ListProductsReply {",
            "\trepeated ProductInfo products = 1;",
            "\tint32 total = 2;",
            "\tint32 page = 3;",
            "\tint32 page_size = 4;",
            "}",
            "",
            "message GenerateEmbeddingsResponse {",
            "\tstring job_id = 1;",
            "\tstring status = 2;",
            "\tint32 estimated_time_seconds = 3;",
            "\tint32 total_products = 4;",
            "}",
            "",
            "message GetEmbeddingStatusResponse {",
            "\tstring job_id = 1;",
            "\tstring status = 2;\t// \"pending\", \"running\", \"completed\", \"failed\", \"cancelled\"",
            "\tint32 processed = 3;",
            "\tint32 total = 4;",
            "\tfloat progress = 5;\t// 0.0 to 1.0",
            "\tstring error_message = 6;",
            "\tgoogle.protobuf.Timestamp started_at = 7;",
            "\tgoogle.protobuf.Timestamp last_updated = 8;",
            "\tgoogle.protobuf.Timestamp estimated_completion = 9;",
            "}",
            "",
            "message StartProductSeedJobResponse {",
            "\tstring job_id = 1;",
            "\tstring status = 2;",
            "\tint32 total_products = 3;",
            "\tint32 estimated_time_seconds = 4;",
            "}",
            "",
            "message GetProductSeedJobStatusResponse {",
            "\tstring job_id = 1;",
            "\tstring status = 2;\t// \"pending\", \"running\", \"completed\", \"failed\", \"cancelled\"",
            "\tint32 processed = 3;",
            "\tint32 total = 4;",
            "\tfloat progress = 5;\t// 0.0 to 1.0",
            "\tint32 seeded = 6;",
            "\tint32 skipped = 7;",
            "\tstring error_message = 8;",
            "\tgoogle.protobuf.Timestamp started_at = 9;",
            "\tgoogle.protobuf.Timestamp last_updated = 10;",
            "\tgoogle.protobuf.Timestamp estimated_completion = 11;",
            "}",
            "",
            "// ========== DATA MESSAGES ==========",
            "",
            "message ProductInfo {",
            "\t// Basic info",
            "\tint64 id = 1;",
            "\tstring original_id = 2;",
            "\tstring title = 3;",
            "\tstring brand = 4;",
            "\tstring description = 5;",
            "\t",
            "\t// Pricing",
            "\tstring actual_price = 6;",
            "\tstring selling_price = 7;",
            "\tstring discount = 8;",
            "\tint32 price_numeric = 9;",
            "\tfloat discount_percentage = 10;",
            "\t",
            "\t// Categorization",
            "\tstring category = 11;",
            "\tstring sub_category = 12;",
            "\t",
            "\t// Stock & Seller",
            "\tbool out_of_stock = 13;",
            "\tstring seller = 14;",
            "\t",
            "\t// Ratings",
            "\tstring average_rating = 15;",
            "\tfloat rating_numeric = 16;",
            "\t",
            "\t// Media",
            "\trepeated string images = 17;",
            "\tstring primary_image = 18;",
            "\t",
            "\t// Product details",
            "\tmap<string, string> product_details = 19;",
            "\t",
            "\t// URLs and identifiers",
            "\tstring url = 20;",
            "\tstring pid = 21;",
            "\tstring style_code = 22;",
            "\t",
            "\t// Timestamps",
            "\tgoogle.protobuf.Timestamp crawled_at = 23;",
            "\tgoogle.protobuf.Timestamp created_at = 24;",
            "\tgoogle.protobuf.Timestamp updated_at = 25;",
            "\t",
            "\t// Engagement metrics",
            "\tint32 view_count = 26;",
            "\tint32 click_count = 27;",
            "\tbool featured = 28;",
            "}",
            "",
            "// ========== COMMON STRUCTURES ==========",
            "",
            "message PriceRange {",
            "\tint32 min = 1;",
            "\tint32 max = 2;",
            "}",
            ""
        ],
        "description": "api/products/v1"
    },

