            "",
            "// Edges of the Product.",
            "func (Product) Edges() []ent.Edge {",
            "\treturn []ent.Edge{",
            "\t\t// Add relationships here if needed",
            "\t\t// For example:",
            "\t\t// edge.To(\"category\", Category.Type),",
            "\t\t// edge.To(\"reviews\", Review.Type),",
            "\t\t// edge.To(\"similar_products\", Product.Type),",
            "\t}",
            "}",
            "",
            "// Indexes for Product",
            "func (Product) Indexes() []ent.Index {",
            "\treturn []ent.Index{",
            "\t\t// Primary indexes",
            "\t\tindex.Fields(\"pid\").Unique(),",
            "\t\tindex.Fields(\"original_id\").Unique(),",
            "",
            "\t\t// Search indexes",
            "\t\tindex.Fields(\"brand\"),",
            "\t\tindex.Fields(\"category\"),",
            "\t\tindex.Fields(\"sub_category\"),",
            "",
            "\t\t// Performance indexes",
            "\t\tindex.Fields(\"price_numeric\"),",
            "\t\tindex.Fields(\"rating_numeric\"),",
            "\t\tindex.Fields(\"out_of_stock\"),",
            "\t\tindex.Fields(\"featured\"),",
            "",
            "\t\t// Composite indexes for common queries",
            "\t\tindex.Fields(\"category\", \"sub_category\"),",
            "\t\tindex.Fields(\"brand\", \"category\"),",
            "\t\tindex.Fields(\"category\", \"price_numeric\"),",
            "\t\tindex.Fields(\"category\", \"rating_numeric\"),",
            "",
            "\t\t// Full-text search (if supported by your DB)",
            "\t\t// index.Fields(\"title\", \"description\", \"search_keywords\").StorageKey(\"product_search_idx\"),",
            "\t}",
            "}",
            "",
            "// Hooks for Product",
            "func (Product) Hooks() []ent.Hook {",
            "\treturn []ent.Hook{",
            "\t\t// Pre-create hook to set numeric fields",
            "\t\thook.On(",
            "\t\t\tfunc(next ent.Mutator) ent.Mutator {",
            "\t\t\t\treturn ent.MutateFunc(func(ctx context.Context, m ent.Mutation) (ent.Value, error) {",
            "\t\t\t\t\t// Convert price string to numeric",
            "\t\t\t\t\tif m.Op().Is(ent.OpCreate | ent.OpUpdate | ent.OpUpdateOne) {",
            "\t\t\t\t\t\tif price, ok := m.Field(\"selling_price\"); ok {",
            "\t\t\t\t\t\t\tpriceStr, _ := price.(string)",
            "\t\t\t\t\t\t\tnumericPrice := extractPriceNumber(priceStr)",
            "\t\t\t\t\t\t\tm.SetField(\"price_numeric\", numericPrice)",
            "\t\t\t\t\t\t}",
            "",
            "\t\t\t\t\t\tif rating, ok := m.Field(\"average_rating\"); ok {",
            "\t\t\t\t\t\t\tratingStr, _ := rating.(string)",
            "\t\t\t\t\t\t\tnumericRating := extractRatingNumber(ratingStr)",
            "\t\t\t\t\t\t\tm.SetField(\"rating_numeric\", numericRating)",
            "\t\t\t\t\t\t}",
            "",
            "\t\t\t\t\t\t// Set crawled_at if empty",
            "\t\t\t\t\t\tif crawledAt, ok := m.Field(\"crawled_at\"); !ok || crawledAt.(time.Time).IsZero() {",
            "\t\t\t\t\t\t\tm.SetField(\"crawled_at\", time.Now())",
            "\t\t\t\t\t\t}",
            "\t\t\t\t\t}",
            "",
            "\t\t\t\t\treturn next.Mutate(ctx, m)",
            "\t\t\t\t})",
            "\t\t\t},",
            "\t\t\tent.OpCreate|ent.OpUpdate|ent.OpUpdateOne,",
            "\t\t),",
            "",
            "\t\t// Generate search keywords",
            "\t\thook.On(",
            "\t\t\tfunc(next ent.Mutator) ent.Mutator {",
            "\t\t\t\treturn ent.MutateFunc(func(ctx context.Context, m ent.Mutation) (ent.Value, error) {",
            "\t\t\t\t\tif m.Op().Is(ent.OpCreate | ent.OpUpdate | ent.OpUpdateOne) {",
            "\t\t\t\t\t\tvar keywords []string",
            "",
            "\t\t\t\t\t\tif title, ok := m.Field(\"title\"); ok {",
            "\t\t\t\t\t\t\ttitleStr, _ := title.(string)",
            "\t\t\t\t\t\t\tkeywords = append(keywords, generateKeywords(titleStr)...)",
            "\t\t\t\t\t\t}",
            "",
            "\t\t\t\t\t\tif brand, ok := m.Field(\"brand\"); ok {",
            "\t\t\t\t\t\t\tbrandStr, _ := brand.(string)",
            "\t\t\t\t\t\t\tkeywords = append(keywords, brandStr)",
            "\t\t\t\t\t\t}",
            "",
            "\t\t\t\t\t\tif category, ok := m.Field(\"category\"); ok {",
            "\t\t\t\t\t\t\tcategoryStr, _ := category.(string)",
            "\t\t\t\t\t\t\tkeywords = append(keywords, categoryStr)",
            "\t\t\t\t\t\t}",
            "",
            "\t\t\t\t\t\tm.SetField(\"search_keywords\", keywords)",
            "\t\t\t\t\t}",
            "",
            "\t\t\t\t\treturn next.Mutate(ctx, m)",
            "\t\t\t\t})",
            "\t\t\t},",
            "\t\t\tent.OpCreate|ent.OpUpdate|ent.OpUpdateOne,",
            "\t\t),",
            "\t}",
            "}",
            "",
            "// Helper functions (add these in a separate helper file)",
            "func extractPriceNumber(priceStr string) int {",
            "\t// Remove commas, ₹, $, etc. and convert to integer",
            "\tpriceStr = strings.ReplaceAll(priceStr, \",\", \"\")",
            "\tpriceStr = strings.ReplaceAll(priceStr, \"₹\", \"\")",
            "\tpriceStr = strings.ReplaceAll(priceStr, \"$\", \"\")",
            "\tpriceStr = strings.ReplaceAll(priceStr, \" \", \"\")",
            "",
            "\tif price, err := strconv.Atoi(priceStr); err == nil {",
            "\t\treturn price",
            "\t}",
            "\treturn 0",
            "}",
            "",
            "func extractRatingNumber(ratingStr string) float64 {",
            "\tif rating, err := strconv.ParseFloat(ratingStr, 64); err == nil {",
            "\t\treturn rating",
            "\t}",
            "\treturn 0.0",
            "}",
            "",
            "func generateKeywords(text string) []string {",
            "\twords := strings.Fields(strings.ToLower(text))",
            "",
            "\t// Common words to exclude",
            "\tstopWords := map[string]bool{",
            "\t\t\"and\": true, \"or\": true, \"the\": true, \"a\": true, \"an\": true,",
            "\t\t\"in\": true, \"on\": true, \"at\": true, \"to\": true, \"for\": true,",
            "\t\t\"with\": true, \"by\": true, \"of\": true, \"men\": true, \"women\": true,",
            "\t}",
            "",
            "\tvar keywords []string",
            "\tfor _, word := range words {",
            "\t\tif !stopWords[word] && len(word) > 2 {",
            "\t\t\tkeywords = append(keywords, word)",
            "\t\t}",
            "\t}",
            "",
            "\treturn keywords",
            "}",
            "",
