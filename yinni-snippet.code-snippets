    "yinni-json-converter": {
        "prefix": "yinni-json-converter",
        "body": [
            "import 'dart:async';",
            "",
            "import 'package:chopper/chopper.dart';",
            "import 'package:flutter/foundation.dart';",
            "",
            "typedef JsonFactory<T> = T Function(Map<String, dynamic> json);",
            "",
            "class JsonModelConverter extends JsonConverter {",
            "\tconst JsonModelConverter(this.factories);",
            "",
            "\tfinal Map<Type, JsonFactory> factories;",
            "",
            "\tT? _decodeMap<T>(Map<String, dynamic> values) {",
            "\t\tfinal jsonFactory = factories[T];",
            "\t\tif (jsonFactory == null || jsonFactory is! JsonFactory<T>) {",
            "\t\t\treturn null;",
            "\t\t}",
            "\t\treturn jsonFactory(values);",
            "\t}",
            "",
            "\tList<T> _decodeList<T>(Iterable values) =>",
            "\t\t\tvalues.where((v) => v != null).map<T>((v) => _decode<T>(v)).toList();",
            "",
