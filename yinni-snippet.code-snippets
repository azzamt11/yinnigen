            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tpasswordFieldType: PasswordFieldType.confirmPassword,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tonSaved: (v) => _passwordConf = v!,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tcontroller: _passwordConfController,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tvalidator: (v) => v == null || v.length < 6",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t? \"Minimum 6 characters\"",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t: v != _passwordController.text",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t? \"Password does not match\" ",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t: null",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\tconst SizedBox(height: 36),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\tBlocBuilder<AuthCubit, AuthState>(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tbuilder: (context, state) {",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tfinal isLoading = state is LoadingAuthState;",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\treturn SizedBox(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\twidth: double.infinity,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\theight: 45,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tchild: ElevatedButton(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tonPressed: isLoading ? null",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t: () {",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tif (_formKey.currentState!.validate()) {",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t_formKey.currentState!.save();",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tcontext.read<AuthCubit>().signUp(_email, _password ?? _passwordConf, _name);",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t}",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t},",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tstyle: ElevatedButton.styleFrom(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tbackgroundColor: Theme.of(context).primaryColor,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\ttapTargetSize: MaterialTapTargetSize.shrinkWrap,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tshape: RoundedRectangleBorder(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tborderRadius: BorderRadius.circular(14),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tchild: isLoading ? Center(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tchild: SizedBox(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\theight: 25,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\twidth: 25,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tchild: CircularProgressIndicator(color: Colors.white, strokeWidth: 2),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t)",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t) :",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tText(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\"Sign Up\",",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tstyle: t.textTheme.titleMedium",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t);",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t},",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\tconst SizedBox(height: 32),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\tRow(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tmainAxisAlignment: MainAxisAlignment.center,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tchildren: [",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tText(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\"New to Yinni? \",",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tstyle: t.textTheme.bodyLarge?.copyWith(color: Colors.black87),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tGestureDetector(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tonTap: () {",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tcontext.router.replace(SignInRoute());",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t},",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tchild: Text(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\"Sign In\",",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tstyle: t.textTheme.bodyLarge?.copyWith(color: t.primaryColor),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t],",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\tconst SizedBox(height: 40),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t],",
            "\t\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t)",
            "\t\t\t\t\t\t\t\t)",
            "\t\t\t\t\t\t\t],",
            "\t\t\t\t\t\t);",
            "\t\t\t\t\t},",
            "\t\t\t\t),",
            "\t\t\t)",
            "\t\t);",
            "\t}",
            "",
            "\tWidget _label(String text, ThemeData t) {",
            "\t\treturn Align(",
            "\t\t\talignment: Alignment.centerLeft,",
            "\t\t\tchild: Text(",
            "\t\t\t\ttext,",
            "\t\t\t\tstyle: t.textTheme.bodyMedium?.copyWith(color: Colors.grey.shade800)",
            "\t\t\t),",
            "\t\t);",
            "\t}",
            "",
            "\tWidget _inputField({",
            "\t\trequired String hint,",
            "\t\trequired ThemeData t,",
            "\t\tTextInputType? keyboardType,",
            "\t\tFormFieldValidator<String>? validator,",
            "\t\tFormFieldSetter<String>? onSaved,",
            "\t\tIterable<String>? autofillHints,",
            "\t\tPasswordFieldType? passwordFieldType,",
            "\t\tTextEditingController? controller",
            "\t}) {",
            "\t\tfinal isPassword = passwordFieldType != null;",
            "",
            "\t\tbool isVisible;",
            "\t\tVoidCallback? toggleVisibility;",
            "",
            "\t\tif (passwordFieldType == PasswordFieldType.password) {",
            "\t\t\tisVisible = _passwordVisible;",
            "\t\t\ttoggleVisibility = () {",
            "\t\t\t\tsetState(() {",
            "\t\t\t\t\t_passwordVisible = !_passwordVisible;",
            "\t\t\t\t});",
            "\t\t\t};",
            "\t\t} else if (passwordFieldType == PasswordFieldType.confirmPassword) {",
            "\t\t\tisVisible = _passwordConfVisible;",
            "\t\t\ttoggleVisibility = () {",
            "\t\t\t\tsetState(() {",
            "\t\t\t\t\t_passwordConfVisible = !_passwordConfVisible;",
            "\t\t\t\t});",
            "\t\t\t};",
            "\t\t} else {",
            "\t\t\tisVisible = true;",
            "\t\t}",
            "",
            "\t\treturn TextFormField(",
            "\t\t\tstyle: t.textTheme.bodyLarge?.copyWith(",
            "\t\t\t\tcolor: Colors.grey.shade800,",
            "\t\t\t),",
            "\t\t\tobscureText: isPassword && !isVisible,",
            "\t\t\tkeyboardType: keyboardType,",
            "\t\t\tvalidator: validator,",
            "\t\t\tonSaved: onSaved,",
            "\t\t\tautofillHints: autofillHints,",
            "\t\t\tenableSuggestions: !isPassword,",
            "\t\t\tautocorrect: !isPassword,",
            "\t\t\tcontroller: controller,",
            "\t\t\tdecoration: InputDecoration(",
            "\t\t\t\thintText: hint,",
            "\t\t\t\tfloatingLabelBehavior: FloatingLabelBehavior.never,",
            "\t\t\t\tfilled: true,",
            "\t\t\t\tfillColor: Colors.white,",
            "",
            "\t\t\t\tcontentPadding: const EdgeInsets.symmetric(",
            "\t\t\t\t\thorizontal: 12,",
            "\t\t\t\t\tvertical: 7,",
            "\t\t\t\t),",
            "",
            "\t\t\t\tenabledBorder: OutlineInputBorder(",
            "\t\t\t\t\tborderRadius: BorderRadius.circular(10),",
            "\t\t\t\t\tborderSide: const BorderSide(color: Colors.black12, width: 0.7),",
            "\t\t\t\t),",
            "",
            "\t\t\t\tfocusedBorder: OutlineInputBorder(",
            "\t\t\t\t\tborderRadius: BorderRadius.circular(10),",
            "\t\t\t\t\tborderSide: BorderSide(color: t.primaryColor, width: 1.2),",
            "\t\t\t\t),",
            "",
            "\t\t\t\terrorBorder: OutlineInputBorder(",
            "\t\t\t\t\tborderRadius: BorderRadius.circular(10),",
            "\t\t\t\t\tborderSide: const BorderSide(color: Colors.redAccent),",
            "\t\t\t\t),",
            "",
            "\t\t\t\tfocusedErrorBorder: OutlineInputBorder(",
            "\t\t\t\t\tborderRadius: BorderRadius.circular(10),",
            "\t\t\t\t\tborderSide: const BorderSide(color: Colors.redAccent, width: 1.2),",
            "\t\t\t\t),",
            "",
            "\t\t\t\tsuffixIcon: isPassword",
            "\t\t\t\t\t\t? IconButton(",
            "\t\t\t\t\t\t\t\ticon: Icon(",
            "\t\t\t\t\t\t\t\t\tisVisible ? Icons.visibility : Icons.visibility_off,",
            "\t\t\t\t\t\t\t\t\tcolor: Colors.grey,",
            "\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\tonPressed: toggleVisibility,",
            "\t\t\t\t\t\t\t)",
            "\t\t\t\t\t\t: null,",
            "\t\t\t),",
            "\t\t);",
            "\t}",
            "}",
            "",
            "enum PasswordFieldType {",
            "\tpassword,",
            "\tconfirmPassword,",
            "}"
        ],
        "description": "lib/features/auth/presentation/screens"
    },

