            "\t\t// Product details (dynamic JSON)",
            "\t\tfield.JSON(\"product_details\", []map[string]string{}).",
            "\t\t\tOptional().",
            "\t\t\tComment(\"Dynamic product attributes\"),",
            "",
            "\t\t// URLs and identifiers",
            "\t\tfield.String(\"url\").",
            "\t\t\tOptional().",
            "\t\t\tMaxLen(2048).",
            "\t\t\tComment(\"Product URL\"),",
            "\t\tfield.String(\"pid\").",
            "\t\t\tUnique().",
            "\t\t\tComment(\"Flipkart product ID\"),",
            "\t\tfield.String(\"style_code\").",
            "\t\t\tOptional().",
