            "\t\t\t\t\t\t\t\t\t\t\t\t\t\tconst SizedBox(height: 8),",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t_inputField(",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tt: t,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\thint: \"Email\",",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tkeyboardType: TextInputType.emailAddress,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tonSaved: (v) => _email = v!,",
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tvalidator: (v) =>",
