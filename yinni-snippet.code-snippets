    "yinni-list-extension": {
        "prefix": "yinni-list-extension",
        "body": [
            "extension ListExtension<T> on Iterable<T> {",
            "",
            "\tT? get firstOrNull {",
            "\t\tif (isEmpty) {",
            "\t\t\treturn null;",
            "\t\t}",
            "\t\treturn first;",
            "\t}",
            "",
            "\tT? get lastOrNull {",
            "\t\tif (isEmpty) {",
            "\t\t\treturn null;",
            "\t\t}",
            "\t\treturn last;",
            "\t}",
            "",
            "\tList<List<T>> group(int groupSize) {",
            "\t\tif (groupSize <= 0) {",
            "\t\t\tthrow ArgumentError('Group size must be greater than 0');",
            "\t\t}",
            "",
            "\t\tfinal List<T> list = toList();",
            "",
            "\t\tList<List<T>> groupedList = [];",
            "\t\tfor (int i = 0; i < list.length; i += groupSize) {",
            "\t\t\tint end = (i + groupSize < list.length) ? i + groupSize : list.length;",
            "\t\t\tgroupedList.add(list.sublist(i, end));",
            "\t\t}",
            "\t\treturn groupedList;",
            "\t}",
            "",
            "\tList<List<Map<String, dynamic>>> groupWithIndex(int groupSize) {",
            "\t\tif (groupSize <= 0) {",
            "\t\t\tthrow ArgumentError('Group size must be greater than 0');",
            "\t\t}",
            "",
            "\t\tfinal List<T> list = toList();",
            "\t\tfinal List<Map<String, dynamic>> indexedList = [];",
            "",
            "\t\tfor (int i = 0; i < list.length; i++) {",
            "\t\t\tindexedList.add({",
            "\t\t\t\t'id': i,",
            "\t\t\t\t'val': list[i],",
            "\t\t\t});",
            "\t\t}",
            "",
            "\t\tfinal List<List<Map<String, dynamic>>> groupedList = [];",
            "\t\tfor (int i = 0; i < indexedList.length; i += groupSize) {",
            "\t\t\tint end = (i + groupSize < indexedList.length) ? i + groupSize : indexedList.length;",
            "\t\t\tgroupedList.add(indexedList.sublist(i, end));",
            "\t\t}",
            "",
            "\t\treturn groupedList;",
            "\t}",
            "",
            "\tList<T?> evenify() {",
            "\t\tfinal List<T> originalList = toList();",
            "\t\tfinal List<T?> evenifiedList = [...originalList];",
            "\t\t",
            "\t\tif (evenifiedList.length.isOdd) {",
            "\t\t\tevenifiedList.add(null);",
            "\t\t}",
            "\t\t",
            "\t\treturn evenifiedList;",
            "\t}",
            "",
            "\tList<Map<String, dynamic>> indexify() {",
            "\t\treturn toList().asMap().entries.map((entry) {",
            "\t\t\treturn {",
            "\t\t\t\t'id': entry.key,",
            "\t\t\t\t'val': entry.value,",
            "\t\t\t};",
            "\t\t}).toList();",
            "\t}",
            "",
            "\tT? firstWhereOrNull(bool Function(T element) test) {",
            "\t\tfor (final element in this) {",
            "\t\t\tif (test(element)) {",
            "\t\t\t\treturn element;",
            "\t\t\t}",
            "\t\t}",
            "\t\treturn null;",
            "\t}",
            "}"
        ],
        "description": "lib/core/extension"
    },

    "yinni-string-extension": {
        "prefix": "yinni-string-extension",
        "body": [
            "extension TranslatableString on String {",
            "\tString tr(String? language) {",
            "",
            "\t\tif(language == \"en\" || language == null) {",
            "\t\t\treturn this;",
            "\t\t}",
            "\t\t",
            "\t\tfinal translations = {",
            "\t\t\t'id': {",
            "\t\t\t\t//words on translation",
            "\t\t\t},",
            "\t\t};",
            "",
            "\t\treturn translations['id']?[this] ?? this;",
            "\t}",
            "",
            "\tString toProperCase() {",
            "\t\tif (isEmpty) {",
            "\t\t\treturn this;",
            "\t\t}",
            "\t\t",
            "\t\tString lowerCaseString = toLowerCase();",
            "\t\t",
            "\t\tList<String> words = lowerCaseString.split(' ');",
            "\t\t",
            "\t\tList<String> properCaseWords = words.map((word) {",
            "\t\t\tif (word.isEmpty) {",
            "\t\t\t\treturn '';",
            "\t\t\t}",
            "\t\t\treturn word[0].toUpperCase() + word.substring(1);",
            "\t\t}).toList();",
            "\t\t",
            "\t\treturn properCaseWords.join(' ');",
            "\t}",
            "}"
        ],
        "description": "lib/core/extension"
    },

    "yinni-app-database": {
        "prefix": "yinni-app-database",
        "body": [
            "part 'app_database.g.dart';",
            "",
            "// --- TYPE CONVERTERS ---",
            "class ProductDataConverter extends TypeConverter<ProductData, String> {",
            "\tconst ProductDataConverter();",
            "\t@override",
            "\tProductData fromSql(String fromDb) => ProductData.fromJson(json.decode(fromDb));",
            "\t@override",
            "\tString toSql(ProductData value) => json.encode(value.toJson());",
            "}",
            "",
            "class UserDataConverter extends TypeConverter<UserData, String> {",
            "\tconst UserDataConverter();",
            "",
            "\t@override",
            "\tUserData fromSql(String fromDb) =>",
            "\t\t\tUserData.fromJson(json.decode(fromDb));",
            "",
            "\t@override",
            "\tString toSql(UserData value) =>",
            "\t\t\tjson.encode(value.toJson());",
            "}",
            "",
            "// --- TABLES ---",
            "",
            "@DataClassName('ProductEntity')",
            "class Products extends Table {",
            "\tTextColumn get id => text()();",
            "\tTextColumn get data => text().map(const ProductDataConverter())();",
            "",
            "\t@override",
            "\tSet<Column> get primaryKey => {id};",
            "}",
            "",
            "@DataClassName('AuthTokenEntity')",
            "class AuthTokens extends Table {",
            "\tTextColumn get key => text()();",
            "\tTextColumn get value => text()();",
            "",
            "\t@override",
            "\tSet<Column> get primaryKey => {key};",
            "}",
            "",
            "@DataClassName('UserEntity')",
            "class Users extends Table {",
            "\tIntColumn get id => integer()();",
            "",
            "\tTextColumn get data =>",
            "\t\t\ttext().map(const UserDataConverter())();",
            "",
            "\t@override",
            "\tSet<Column> get primaryKey => {id};",
            "}",
            "",
            "// --- DATABASE CLASS ---",
            "",
            "@DriftDatabase(tables: [Products, AuthTokens, Users])",
            "class AppDatabase extends _$AppDatabase {",
            "\tAppDatabase() : super(_openConnection());",
            "",
            "\t@override",
            "\tint get schemaVersion => 1;",
            "",
            "\t// ---------------------------------------------------------------------------",
            "\t// PRODUCT SERVICE LOGIC",
            "\t// ---------------------------------------------------------------------------",
            "\tFuture<void> saveProducts(List<ProductData> items) async {",
            "\t\tawait batch((batch) {",
            "\t\t\tbatch.insertAllOnConflictUpdate(",
            "\t\t\t\tproducts,",
            "\t\t\t\titems.map((item) => ProductEntity(",
            "\t\t\t\t\tid: item.id, ",
            "\t\t\t\t\tdata: item,",
            "\t\t\t\t)).toList(),",
            "\t\t\t);",
            "\t\t});",
            "\t}",
            "",
            "\tFuture<List<ProductData>> getAllProducts() async {",
            "\t\tfinal result = await select(products).get();",
            "\t\treturn result.map((row) => row.data).toList();",
            "\t}",
            "",
            "\t// ---------------------------------------------------------------------------",
            "\t// AUTH SERVICE LOGIC",
            "\t// ---------------------------------------------------------------------------",
            "\tFuture<void> saveToken(String key, String value) async {",
            "\t\tawait into(authTokens).insertOnConflictUpdate(",
            "\t\t\tAuthTokenEntity(key: key, value: value),",
            "\t\t);",
            "\t}",
            "",
            "\tFuture<String?> getToken(String key) async {",
            "\t\tfinal query = select(authTokens)..where((t) => t.key.equals(key));",
            "\t\tfinal row = await query.getSingleOrNull();",
            "\t\treturn row?.value;",
            "\t}",
            "",
            "\tFuture<void> saveUser(UserData user) async {",
            "\t\tawait into(users).insertOnConflictUpdate(",
            "\t\t\tUserEntity(id: user.id, data: user),",
            "\t\t);",
            "\t}",
            "",
            "\tFuture<UserData?> getCurrentUser() async {",
            "\t\tfinal row = await select(users).getSingleOrNull();",
            "\t\treturn row?.data;",
            "\t}",
            "",
            "\tFuture<void> clearAuth() async {",
            "\t\tawait batch((batch) {",
            "\t\t\tbatch.deleteAll(authTokens);",
            "\t\t\tbatch.deleteAll(users);",
            "\t\t});",
            "\t}",
            "}",
            "",
            "// --- CONNECTION ---",
            "",
            "LazyDatabase _openConnection() {",
            "\treturn LazyDatabase(() async {",
            "\t\tfinal dbFolder = await getApplicationDocumentsDirectory();",
            "\t\tfinal file = File(p.join(dbFolder.path, 'db.sqlite'));",
            "\t\treturn NativeDatabase.createInBackground(file);",
            "\t});",
            "}"
        ],
        "description": "lib/core/repositories/cache/database"
    },

