        "body": [
            "import 'dart:async';",
            "import 'package:chopper/chopper.dart';",
            "import 'package:flutter/foundation.dart';",
            "import 'package:http/http.dart' as http;",
            "",
            "class ServiceLoggingInterceptor implements Interceptor {",
            "\t@override",
            "\tFutureOr<Response<BodyType>> intercept<BodyType>(Chain<BodyType> chain) async {",
            "\t\tfinal Request request = chain.request;",
            "",
            "\t\t// --- 1. Log Request ---",
            "\t\tdebugPrint('==================== REQUEST START ====================');",
            "\t\tdebugPrint('--> ${request.method} ${request.url}');",
            "\t\tfinal http.BaseRequest baseRequest = await request.toBaseRequest();",
            "\t\tif (baseRequest is http.Request && baseRequest.body.isNotEmpty) {",
            "\t\t\tdebugPrint('Body: ${baseRequest.body}');",
            "\t\t}",
            "\t\tdebugPrint('====================== REQUEST END =====================');",
            "",
            "\t\tfinal Stopwatch stopWatch = Stopwatch()..start();",
            "",
            "\t\ttry {",
            "\t\t\tfinal Response<BodyType> response = await chain.proceed(request);",
            "\t\t\tstopWatch.stop();",
            "\t\t\treturn response;",
            "\t\t} catch (e) {",
            "\t\t\tstopWatch.stop();",
            "\t\t\tdebugPrint('==================== ERROR START ===================');",
            "\t\t\tdebugPrint('URL: ${request.url}');",
            "\t\t\tdebugPrint('TIME: ${stopWatch.elapsedMilliseconds}ms');",
            "\t\t\t",
            "\t\t\t// Check if it's a Chopper error that contains the response",
            "\t\t\tif (e is Response) {",
            "\t\t\t\tdebugPrint('Status Code: ${e.statusCode}');",
            "\t\t\t\tdebugPrint('Raw Body from Error: ${e.bodyString}');",
            "\t\t\t}",
            "\t\t\t",
            "\t\t\tdebugPrint('ERROR DETAILS: $e');",
            "\t\t\tdebugPrint('==================== ERROR END ========================');",
            "\t\t\trethrow;",
            "\t\t}",
            "\t}",
            "}"
        ],
        "description": "lib/core/repositories/network"
    },

