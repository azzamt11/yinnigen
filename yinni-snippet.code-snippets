            "@RoutePage()",
            "class InitialScreen extends StatefulWidget {",
            "\tconst InitialScreen({super.key});",
            "",
            "\t@override",
            "\tState<InitialScreen> createState() => _InitialScreenState();",
            "}",
            "",
            "class _InitialScreenState extends State<InitialScreen> with TickerProviderStateMixin {",
            "\tlate AnimationController _drawerController;",
            "\tlate PageController _pageController;",
            "\tlate List<AnimationController> _progressControllers;",
            "\t",
            "\tbool _drawerShown = false;",
            "\tint _currentPage = 0;",
            "",
            "\tfinal int pageCount = 3;",
            "\tfinal Duration progressDuration = const Duration(seconds: 5);",
            "",
            "\t@override",
            "\tvoid initState() {",
            "\t\tsuper.initState();",
            "",
            "\t\t_pageController = PageController();",
            "",
            "\t\t_progressControllers = List.generate(",
            "\t\t\tpageCount,",
            "\t\t\t(_) => AnimationController(",
            "\t\t\t\tvsync: this,",
            "\t\t\t\tduration: progressDuration,",
            "\t\t\t),",
            "\t\t);",
            "",
            "\t\t_drawerController = AnimationController(",
            "\t\t\tvsync: this,",
            "\t\t\tduration: const Duration(milliseconds: 500),",
            "\t\t);",
            "",
            "\t\t_startProgress(0);",
            "\t}",
            "",
            "\tvoid _startProgress(int index) {",
            "\t\tfor (int i = 0; i < pageCount; i++) {",
            "\t\t\tif (i < index) {",
            "\t\t\t\t_progressControllers[i].value = 1.0;",
            "\t\t\t} else if (i > index) {",
            "\t\t\t\t_progressControllers[i].value = 0.0;",
            "\t\t\t} else {",
            "\t\t\t\t_progressControllers[i]",
            "\t\t\t\t\t..reset()",
            "\t\t\t\t\t..forward();",
            "\t\t\t}",
            "\t\t}",
            "",
            "\t\t_progressControllers[index].addStatusListener((status) {",
            "\t\t\tif (status == AnimationStatus.completed &&",
            "\t\t\t\t\tindex == _currentPage) {",
            "",
            "\t\t\t\tif (index < pageCount - 1) {",
            "\t\t\t\t\t_pageController.nextPage(",
            "\t\t\t\t\t\tduration: const Duration(milliseconds: 300),",
            "\t\t\t\t\t\tcurve: Curves.easeInOut,",
            "\t\t\t\t\t);",
            "\t\t\t\t} else if (!_drawerShown) {",
            "\t\t\t\t\t_drawerShown = true;",
            "\t\t\t\t\t_drawerController.forward();",
            "\t\t\t\t}",
            "\t\t\t}",
            "\t\t});",
            "\t}",
            "",
            "\tvoid _onPageChanged(int index) {",
            "\t\tif (index < _currentPage) {",
            "\t\t\t_progressControllers[index].reset();",
            "\t\t}",
            "",
            "\t\t_currentPage = index;",
            "\t\t_startProgress(index);",
            "\t}",
            "",
            "\t@override",
            "\tvoid dispose() {",
            "\t\t_pageController.dispose();",
            "\t\tfor (final c in _progressControllers) {",
            "\t\t\tc.dispose();",
            "\t\t}",
            "\t\tsuper.dispose();",
            "\t}",
            "",
            "\t@override",
            "\tWidget build(BuildContext context) {",
            "\t\treturn Scaffold(",
            "\t\t\tbody: Stack(",
            "\t\t\t\tchildren: [",
            "\t\t\t\t\tPageView(",
            "\t\t\t\t\t\tcontroller: _pageController,",
            "\t\t\t\t\t\tonPageChanged: _onPageChanged,",
            "\t\t\t\t\t\tchildren: [",
            "\t\t\t\t\t\t\tImage.asset(",
            "\t\t\t\t\t\t\t\t'assets/features/initial/poster_1.png',",
            "\t\t\t\t\t\t\t\tfit: BoxFit.cover,",
            "\t\t\t\t\t\t\t\twidth: double.infinity,",
            "\t\t\t\t\t\t\t\theight: double.infinity,",
            "\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\tImage.asset(",
            "\t\t\t\t\t\t\t\t'assets/features/initial/poster_2.png',",
            "\t\t\t\t\t\t\t\tfit: BoxFit.cover,",
            "\t\t\t\t\t\t\t\twidth: double.infinity,",
            "\t\t\t\t\t\t\t\theight: double.infinity,",
            "\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\tImage.asset(",
            "\t\t\t\t\t\t\t\t'assets/features/initial/poster_3.png',",
            "\t\t\t\t\t\t\t\tfit: BoxFit.cover,",
            "\t\t\t\t\t\t\t\twidth: double.infinity,",
            "\t\t\t\t\t\t\t\theight: double.infinity,",
            "\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t],",
            "\t\t\t\t\t),",
            "\t\t\t\t\tPositioned(",
            "\t\t\t\t\t\ttop: 0,",
            "\t\t\t\t\t\tleft: 0,",
            "\t\t\t\t\t\tright: 0,",
            "\t\t\t\t\t\tchild: Column(",
            "\t\t\t\t\t\t\tchildren: [",
            "\t\t\t\t\t\t\t\tContainer(",
            "\t\t\t\t\t\t\t\t\theight: MediaQuery.of(context).padding.top,",
            "\t\t\t\t\t\t\t\t\twidth: double.infinity,",
            "\t\t\t\t\t\t\t\t\tdecoration: BoxDecoration(",
            "\t\t\t\t\t\t\t\t\t\tcolor: Colors.black26,",
            "\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\tPadding(",
            "\t\t\t\t\t\t\t\t\tpadding: const EdgeInsets.symmetric(vertical: 10, horizontal: 10),",
            "\t\t\t\t\t\t\t\t\tchild: _indicator(),",
            "\t\t\t\t\t\t\t\t)",
            "\t\t\t\t\t\t\t],",
            "\t\t\t\t\t\t),",
            "\t\t\t\t\t),",
            "\t\t\t\t\tOnboardingDrawer(animation: _drawerController),",
            "\t\t\t\t],",
            "\t\t\t),",
            "\t\t);",
            "\t}",
            "",
            "\tWidget _indicator() {",
            "\t\treturn Positioned(",
            "\t\t\ttop: 20,",
            "\t\t\tleft: 20,",
            "\t\t\tright: 20,",
            "\t\t\tchild: Row(",
            "\t\t\t\tchildren: List.generate(pageCount, (index) {",
            "\t\t\t\t\treturn Expanded(",
            "\t\t\t\t\t\tchild: Container(",
            "\t\t\t\t\t\t\tmargin: const EdgeInsets.symmetric(horizontal: 4),",
            "\t\t\t\t\t\t\theight: 6,",
            "\t\t\t\t\t\t\tdecoration: BoxDecoration(",
            "\t\t\t\t\t\t\t\tcolor: Colors.black12,",
            "\t\t\t\t\t\t\t\tborderRadius: BorderRadius.circular(3),",
            "\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\tchild: AnimatedBuilder(",
            "\t\t\t\t\t\t\t\tanimation: _progressControllers[index],",
            "\t\t\t\t\t\t\t\tbuilder: (context, _) {",
            "\t\t\t\t\t\t\t\t\treturn FractionallySizedBox(",
            "\t\t\t\t\t\t\t\t\t\talignment: Alignment.centerLeft,",
            "\t\t\t\t\t\t\t\t\t\twidthFactor: _progressControllers[index].value,",
            "\t\t\t\t\t\t\t\t\t\tchild: Container(",
            "\t\t\t\t\t\t\t\t\t\t\tdecoration: BoxDecoration(",
            "\t\t\t\t\t\t\t\t\t\t\t\tcolor: Colors.white,",
            "\t\t\t\t\t\t\t\t\t\t\t\tborderRadius: BorderRadius.circular(3),",
            "\t\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t\t\t\t);",
            "\t\t\t\t\t\t\t\t},",
            "\t\t\t\t\t\t\t),",
            "\t\t\t\t\t\t),",
            "\t\t\t\t\t);",
            "\t\t\t\t}),",
            "\t\t\t),",
            "\t\t);",
            "\t}",
            "}",
            ""
