    "yinni-di": {
        "prefix": "yinni-di",
        "body": [
            "final injector = GetIt.instance;",
            "",
            "Future<void> injectServices() async {",
            "\t// --- 1. JSON Serialization Setup ---",
            "\tinjector.registerSingleton<Map<Type, JsonFactory>>(<Type, JsonFactory>{});",
            "\t",
            "\t// --- 2. Register Model Factories ---",
            "\tinjector.get<Map<Type, JsonFactory>>().addAll({",
            "\t\tProductListApiResponse: ProductListApiResponse.fromJson,",
            "\t\tSignInApiResponse: SignInApiResponse.fromJson,",
            "\t\tSignUpApiResponse: SignUpApiResponse.fromJson,",
            "\t});",
            "",
            "\tinjector.registerLazySingleton<JsonModelConverter>(() => JsonModelConverter(",
            "\t\tinjector.get<Map<Type, JsonFactory>>(),",
            "\t));",
            "",
            "\t// --- 3. Database & Auth Logic ---",
            "\tinjector.registerSingleton<AppDatabase>(AppDatabase());",
            "",
            "\t// AuthUsecase needs the database to retrieve/save tokens.",
            "\tinjector.registerLazySingleton<AuthUsecase>(() => AuthUsecase(",
            "\t\tinjector.get<AppDatabase>(),",
            "\t));",
            "",
            "\tinjector.registerLazySingleton<ImageUrlCacheManager>(() => ImageUrlCacheManager.create());",
            "",
            "\t// --- 4. Network Orchestration (ServiceManager) ---",
            "\tinjector.registerLazySingleton<ServiceManager>(() => ServiceManager.create(",
            "\t\tConfigs.baseUrl,",
            "\t\tinjector.get<JsonModelConverter>(),",
            "\t\tinjector.get<AuthUsecase>(),",
            "\t));",
            "",
            "\t// --- 5. Chopper Services (Client-Specific) ---",
            "\tfinal sm = injector.get<ServiceManager>();",
            "",
            "\t// Product Client (Port 8002)",
            "\tinjector.registerSingleton<ProductService>(",
            "\t\tProductService.create(sm.productClient),",
            "\t);",
            "",
            "\t// Auth Client (Port 8000)",
            "\tinjector.registerSingleton<AuthService>(",
            "\t\tAuthService.create(sm.authClient),",
            "\t);",
            "",
            "\t// --- 6. Repositories ---",
            "\tinjector.registerLazySingleton<AuthRepository>(() => AuthRepository(",
            "\t\tinjector.get<AuthService>(),",
            "\t\tinjector.get<AuthUsecase>(),",
            "\t\tinjector.get<AppDatabase>()",
            "\t));",
            "",
            "\tinjector.registerLazySingleton<HomeRepository>(() => HomeRepository(",
            "\t\tinjector.get<ProductService>(),",
            "\t\tinjector.get<AppDatabase>(),",
            "\t));",
            "}"
        ],
        "description": "lib/core/di"
    },

