        "prefix": "yinni-auth-usecase",
        "body": [
            "import 'dart:async';",
            "import 'package:chopper/chopper.dart';", 
            "",
            "class AuthUsecase {",
            "\tfinal AppDatabase _db;",
            "\tString? _cachedToken;",
            "",
            "\tAuthUsecase(this._db);",
            "",
            "\tstatic AuthUsecase create() =>",
            "\t\tAuthUsecase(injector.get());",
            "",
            "\tFuture<void> initializeToken() async {",
            "\t\ttry {",
            "\t\t\t_cachedToken = await _db.getToken('access_token');",
            "\t\t} catch (e) {",
            "\t\t\t_cachedToken = null;",
            "\t\t}",
            "\t}",
            "",
            "\tString? get cachedToken => _cachedToken;",
            "",
            "\tFuture<void> setToken(String token) async {",
            "\t\tawait _db.saveToken('access_token', token);",
            "\t\t_cachedToken = token;",
            "\t}",
            "",
            "\tFuture<void> clearToken() async {",
            "\t\tawait _db.clearAuth();",
            "\t\t_cachedToken = null;",
            "\t}",
            "",
            "\tFutureOr<Request> addAuthHeaderInterceptor(Request request) async {",
            "\t\tif (_cachedToken == null) {",
            "\t\t\tawait initializeToken();",
            "\t\t}",
            "",
            "\t\tif (_cachedToken != null) {",
            "\t\t\trequest = request.copyWith(",
            "\t\t\t\theaders: {",
            "\t\t\t\t\t...request.headers,",
            "\t\t\t\t\t'Authorization': 'Bearer $_cachedToken',",
            "\t\t\t\t},",
            "\t\t\t);",
            "\t\t}",
            "",
            "\t\tif (request.multipart) {",
            "\t\t\trequest = request.copyWith(headers: {",
            "\t\t\t\t...request.headers,",
            "\t\t\t\t'Content-Type': 'multipart/form-data',",
            "\t\t\t});",
            "\t\t}",
            "",
            "\t\treturn request;",
            "\t}",
            "}"
        ],
        "description": "lib/features/auth/domain/usecase"
    },

