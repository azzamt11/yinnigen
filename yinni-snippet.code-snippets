            "func NewHTTPServer(c *conf.Server, authConf *conf.Auth, product *service.ProductService, logger log.Logger) *http.Server {",
            "\tcorsHandler := cors.New(cors.Options{",
            "\t\tAllowedOrigins:\t []string{\"*\"},",
            "\t\tAllowedMethods:\t []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},",
            "\t\tAllowedHeaders:\t []string{\"*\"},",
            "\t\tAllowCredentials: true,",
            "\t})",
            "",
            "\tvar opts = []http.ServerOption{",
            "\t\thttp.Middleware(",
            "\t\t\trecovery.Recovery(),",
            "\t\t\tlogging.Server(logger),",
            "\t\t\tmiddleware.JWT(authConf.JwtSecret),",
            "\t\t\tmiddleware.Admin(authConf.JwtSecret),",
            "\t\t),",
            "\t\thttp.Filter(corsHandler.Handler),",
            "\t}",
            "\tif c.Http.Network != \"\" {",
            "\t\topts = append(opts, http.Network(c.Http.Network))",
            "\t}",
            "\tif c.Http.Addr != \"\" {",
            "\t\topts = append(opts, http.Address(c.Http.Addr))",
            "\t}",
            "\tif c.Http.Timeout != nil {",
            "\t\topts = append(opts, http.Timeout(c.Http.Timeout.AsDuration()))",
            "\t}",
            "",
            "\tsrv := http.NewServer(opts...)",
            "\tv1.RegisterProductHTTPServer(srv, product)",
            "\treturn srv",
            "}",
            ""
        ],
        "description": "products/internal/server/http.go"
    },

