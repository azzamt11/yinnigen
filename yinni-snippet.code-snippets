    "yinni-service-products-internal-data-function-list-proiducts": {
        "prefix": "yinni-service-pidflp",
        "body": [
            "func (r *productRepo) ListProducts(ctx context.Context, params *biz.ListProductsParams) ([]*biz.Product, int64, error) {",
            "\tquery := r.data.ent.Product.Query()",
            "",
            "\t// Apply filters",
            "\tif params.Category != \"\" {",
            "\t\tquery = query.Where(product.Category(params.Category))",
            "\t}",
            "\tif params.SubCategory != \"\" {",
            "\t\tquery = query.Where(product.SubCategory(params.SubCategory))",
            "\t}",
            "\tif params.Brand != \"\" {",
            "\t\tquery = query.Where(product.Brand(params.Brand))",
            "\t}",
            "\tif params.Seller != \"\" {",
            "\t\tquery = query.Where(product.Seller(params.Seller))",
            "\t}",
            "\tif params.MinPrice > 0 {",
            "\t\tquery = query.Where(product.PriceNumericGTE(int(params.MinPrice)))",
            "\t}",
            "\tif params.MaxPrice > 0 {",
            "\t\tquery = query.Where(product.PriceNumericLTE(int(params.MaxPrice)))",
            "\t}",
            "\tif params.MinRating > 0 {",
            "\t\tquery = query.Where(product.RatingNumericGTE(float64(params.MinRating)))",
            "\t}",
            "\tif params.InStock {",
            "\t\tquery = query.Where(product.OutOfStock(false))",
            "\t}",
            "\tif params.Featured {",
            "\t\tquery = query.Where(product.Featured(true))",
            "\t}",
            "",
            "\t// Apply search query if provided",
            "\tif params.SearchQuery != \"\" {",
            "\t\t// Simple text search (could be enhanced with full-text search)",
            "\t\tquery = query.Where(",
            "\t\t\tproduct.Or(",
            "\t\t\t\tproduct.TitleContains(params.SearchQuery),",
            "\t\t\t\tproduct.DescriptionContains(params.SearchQuery),",
            "\t\t\t\tproduct.BrandContains(params.SearchQuery),",
            "\t\t\t),",
            "\t\t)",
            "\t}",
            "",
            "\t// Apply sorting",
            "\tswitch strings.ToLower(params.SortBy) {",
            "\tcase \"price\":",
            "\t\tif strings.ToLower(params.SortOrder) == \"asc\" {",
            "\t\t\tquery = query.Order(ent.Asc(product.FieldPriceNumeric))",
            "\t\t} else {",
            "\t\t\tquery = query.Order(ent.Desc(product.FieldPriceNumeric))",
            "\t\t}",
            "\tcase \"rating\":",
            "\t\tif strings.ToLower(params.SortOrder) == \"asc\" {",
            "\t\t\tquery = query.Order(ent.Asc(product.FieldRatingNumeric))",
            "\t\t} else {",
            "\t\t\tquery = query.Order(ent.Desc(product.FieldRatingNumeric))",
            "\t\t}",
            "\tcase \"newest\":",
            "\t\tquery = query.Order(ent.Desc(product.FieldCreateTime))",
            "\tcase \"popular\":",
            "\t\tquery = query.Order(ent.Desc(product.FieldViewCount))",
            "\tdefault:",
            "\t\tquery = query.Order(ent.Desc(product.FieldCreateTime))",
            "\t}",
            "",
            "\t// Get total count",
            "\ttotal, err := query.Count(ctx)",
            "\tif err != nil {",
            "\t\treturn nil, 0, err",
            "\t}",
            "",
            "\t// Apply pagination",
            "\toffset := (int(params.Page) - 1) * int(params.PageSize)",
            "\trows, err := query.",
            "\t\tOffset(offset).",
            "\t\tLimit(int(params.PageSize)).",
            "\t\tAll(ctx)",
            "",
            "\tif err != nil {",
            "\t\treturn nil, 0, err",
            "\t}",
            "",
            "\trv := make([]*biz.Product, 0, len(rows))",
            "\tfor _, row := range rows {",
            "\t\trv = append(rv, convertEntToBiz(row))",
            "\t}",
            "\treturn rv, int64(total), nil",
            "}"
        ],
        "description": "api/products/internal/data/products.go"
    },

